# Etapa de dependencias y ejecución
FROM node:22-alpine

WORKDIR /app

# Copiar archivos de dependencias
COPY package*.json ./

# Instalar solo dependencias de producción para ahorrar espacio en disco
RUN npm ci --only=production

# Copiar el resto del código del backend
COPY . .

# Exponer el puerto interno de Express (ajústalo si usas otro diferente)
EXPOSE 3000

# Comando de arranque para producción
CMD ["npm", "start"]